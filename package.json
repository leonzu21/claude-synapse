{
  "name": "claude-synapse",
  "version": "1.0.3",
  "description": "Neural network visualization for Claude Code agent sessions",
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "visualization",
    "neural-network",
    "hooks"
  ],
  "license": "MIT",
  "author": "Iulian Leon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonzu21/claude-synapse.git"
  },
  "bin": {
    "claude-synapse": "./bin/synapse.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "hooks/",
    "LICENSE"
  ],
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "start": "node bin/synapse.mjs",
    "bundle": "node scripts/bundle.mjs",
    "prepublishOnly": "node scripts/bundle.mjs"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
